<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Salary Distribution Calculator</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f4f4f0;
      color: #1a1a18;
      min-height: 100vh;
      padding: 2rem 1rem;
    }

    @media (prefers-color-scheme: dark) {
      body { background: #1a1a18; color: #f0ede8; }
      .card { background: #242422; border-color: rgba(255,255,255,0.1); }
      .metric-card { background: #2c2c2a; }
      input, select { background: #2c2c2a; color: #f0ede8; border-color: rgba(255,255,255,0.2); }
      .bar-track { background: #2c2c2a; }
      .pct-input { background: #2c2c2a; color: #f0ede8; border-color: rgba(255,255,255,0.2); }
    }

    .container { max-width: 540px; margin: 0 auto; }

    h1 {
      font-size: 22px;
      font-weight: 500;
      margin-bottom: 0.25rem;
    }

    .subtitle {
      font-size: 14px;
      color: #888780;
      margin-bottom: 1.5rem;
    }

    .card {
      background: #fff;
      border: 0.5px solid rgba(0,0,0,0.12);
      border-radius: 12px;
      padding: 1rem 1.25rem;
      margin-bottom: 1.25rem;
    }

    .section-label {
      font-size: 13px;
      color: #888780;
      font-weight: 500;
      margin-bottom: 12px;
    }

    .input-row {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .input-group { display: flex; flex-direction: column; gap: 6px; }
    .input-group label { font-size: 13px; color: #888780; }

    input[type="number"], select {
      font-size: 16px;
      padding: 8px 12px;
      border-radius: 8px;
      border: 0.5px solid rgba(0,0,0,0.2);
      background: #fff;
      color: #1a1a18;
      outline: none;
      width: 100%;
    }

    input[type="number"]:focus, select:focus {
      border-color: #378ADD;
      box-shadow: 0 0 0 3px rgba(55,138,221,0.15);
    }

    #salary { font-size: 20px; }

    .alloc-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 12px;
    }

    .dot {
      width: 10px; height: 10px;
      border-radius: 2px;
      flex-shrink: 0;
    }

    .alloc-row span.lbl {
      font-size: 14px;
      color: #5F5E5A;
      flex: 1;
    }

    @media (prefers-color-scheme: dark) {
      .alloc-row span.lbl { color: #B4B2A9; }
    }

    .pct-input {
      width: 56px;
      padding: 4px 6px;
      font-size: 14px;
      text-align: center;
      border-radius: 8px;
      border: 0.5px solid rgba(0,0,0,0.2);
      background: #fff;
      color: #1a1a18;
    }

    .pct-sym { font-size: 13px; color: #888780; }

    .warning {
      font-size: 12px;
      color: #c0392b;
      margin-top: 4px;
      display: none;
    }

    .total-note { font-size: 12px; color: #888780; margin-top: 6px; }

    .metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-bottom: 1.25rem;
    }

    .metric-card {
      background: #f4f4f0;
      border-radius: 8px;
      padding: 0.85rem 0.75rem;
      text-align: center;
    }

    .metric-card p.lbl { font-size: 12px; color: #888780; margin-bottom: 4px; }
    .metric-card p.val { font-size: 18px; font-weight: 500; }

    .bar-section { margin-bottom: 14px; }
    .bar-header { display: flex; justify-content: space-between; margin-bottom: 4px; }
    .bar-header span { font-size: 13px; font-weight: 500; }
    .bar-track {
      height: 12px;
      border-radius: 6px;
      background: #f4f4f0;
      overflow: hidden;
    }
    .bar-fill { height: 100%; border-radius: 6px; transition: width 0.4s ease; }

    .chart-wrap { position: relative; width: 100%; height: 220px; margin-top: 1.25rem; }

    .placeholder {
      text-align: center;
      padding: 2.5rem 0;
      font-size: 14px;
      color: #888780;
    }

    #results { display: none; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Salary Distribution</h1>
    <p class="subtitle">Split your salary into savings, expenses, and debt.</p>

    <div class="card">
      <div class="input-row">
        <div class="input-group" style="flex:1;min-width:160px">
          <label for="salary">Monthly salary</label>
          <input id="salary" type="number" min="0" step="100" placeholder="e.g. 30000" oninput="recalc()">
        </div>
        <div class="input-group">
          <label for="currency">Currency</label>
          <select id="currency" onchange="recalc()">
            <option value="₱">PHP ₱</option>
            <option value="$">USD $</option>
            <option value="€">EUR €</option>
            <option value="£">GBP £</option>
          </select>
        </div>
      </div>
    </div>

    <div class="card">
      <p class="section-label">Allocation percentages</p>

      <div class="alloc-row">
        <span class="dot" style="background:#1D9E75"></span>
        <span class="lbl">Savings / investment</span>
        <input class="pct-input" id="pct-savings" type="number" min="0" max="100" value="10" oninput="recalc()">
        <span class="pct-sym">%</span>
      </div>
      <div class="alloc-row">
        <span class="dot" style="background:#378ADD"></span>
        <span class="lbl">Expenses</span>
        <input class="pct-input" id="pct-expenses" type="number" min="0" max="100" value="70" oninput="recalc()">
        <span class="pct-sym">%</span>
      </div>
      <div class="alloc-row">
        <span class="dot" style="background:#D85A30"></span>
        <span class="lbl">Debt payments</span>
        <input class="pct-input" id="pct-debt" type="number" min="0" max="100" value="20" oninput="recalc()">
        <span class="pct-sym">%</span>
      </div>

      <div class="warning" id="pct-warning">Percentages must add up to 100%.</div>
      <p class="total-note">Total: <span id="total-num">100</span>%</p>
    </div>

    <div id="results">
      <div class="metrics">
        <div class="metric-card">
          <p class="lbl">Savings</p>
          <p class="val" id="v-savings" style="color:#0F6E56">—</p>
        </div>
        <div class="metric-card">
          <p class="lbl">Expenses</p>
          <p class="val" id="v-expenses" style="color:#185FA5">—</p>
        </div>
        <div class="metric-card">
          <p class="lbl">Debt</p>
          <p class="val" id="v-debt" style="color:#993C1D">—</p>
        </div>
      </div>

      <div class="card">
        <div class="bar-section">
          <div class="bar-header">
            <span style="color:#0F6E56">Savings / investment</span>
            <span id="bar-savings-lbl" style="color:#1a1a18"></span>
          </div>
          <div class="bar-track"><div class="bar-fill" id="bar-savings" style="background:#1D9E75"></div></div>
        </div>
        <div class="bar-section">
          <div class="bar-header">
            <span style="color:#185FA5">Expenses</span>
            <span id="bar-expenses-lbl" style="color:#1a1a18"></span>
          </div>
          <div class="bar-track"><div class="bar-fill" id="bar-expenses" style="background:#378ADD"></div></div>
        </div>
        <div class="bar-section">
          <div class="bar-header">
            <span style="color:#993C1D">Debt payments</span>
            <span id="bar-debt-lbl" style="color:#1a1a18"></span>
          </div>
          <div class="bar-track"><div class="bar-fill" id="bar-debt" style="background:#D85A30"></div></div>
        </div>

        <div class="chart-wrap">
          <canvas id="donut" role="img" aria-label="Donut chart showing salary split across savings, expenses, and debt"></canvas>
        </div>
      </div>
    </div>

    <div class="placeholder" id="placeholder">Enter your salary above to see the breakdown.</div>
  </div>

  <script>
    let chart = null;

    function fmt(sym, val) {
      return sym + Math.round(val).toLocaleString();
    }

    function recalc() {
      const sal = parseFloat(document.getElementById('salary').value) || 0;
      const sym = document.getElementById('currency').value;
      const p1 = parseFloat(document.getElementById('pct-savings').value) || 0;
      const p2 = parseFloat(document.getElementById('pct-expenses').value) || 0;
      const p3 = parseFloat(document.getElementById('pct-debt').value) || 0;
      const total = p1 + p2 + p3;

      document.getElementById('total-num').textContent = total.toFixed(0);
      const warn = document.getElementById('pct-warning');
      warn.style.display = Math.abs(total - 100) > 0.01 ? 'block' : 'none';

      if (sal <= 0 || Math.abs(total - 100) > 0.01) {
        document.getElementById('results').style.display = 'none';
        document.getElementById('placeholder').style.display = 'block';
        return;
      }

      document.getElementById('results').style.display = 'block';
      document.getElementById('placeholder').style.display = 'none';

      const s = sal * p1 / 100;
      const e = sal * p2 / 100;
      const d = sal * p3 / 100;

      document.getElementById('v-savings').textContent = fmt(sym, s);
      document.getElementById('v-expenses').textContent = fmt(sym, e);
      document.getElementById('v-debt').textContent = fmt(sym, d);

      document.getElementById('bar-savings').style.width = p1 + '%';
      document.getElementById('bar-expenses').style.width = p2 + '%';
      document.getElementById('bar-debt').style.width = p3 + '%';
      document.getElementById('bar-savings-lbl').textContent = p1 + '% — ' + fmt(sym, s);
      document.getElementById('bar-expenses-lbl').textContent = p2 + '% — ' + fmt(sym, e);
      document.getElementById('bar-debt-lbl').textContent = p3 + '% — ' + fmt(sym, d);

      const data = [s, e, d];
      const colors = ['#1D9E75','#378ADD','#D85A30'];
      const labels = ['Savings / investment', 'Expenses', 'Debt payments'];

      if (chart) {
        chart.data.datasets[0].data = data;
        chart.update();
      } else {
        chart = new Chart(document.getElementById('donut'), {
          type: 'doughnut',
          data: {
            labels,
            datasets: [{ data, backgroundColor: colors, borderWidth: 2, borderColor: 'transparent', hoverOffset: 6 }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '62%',
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: ctx => ' ' + fmt(sym, ctx.parsed) + '  (' + (ctx.parsed / sal * 100).toFixed(1) + '%)'
                }
              }
            }
          }
        });
      }
    }
  </script>
</body>
</html>
